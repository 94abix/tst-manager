# Configuration Serveur TST Manager
# Copier ce fichier en .env et remplir les valeurs

# Port du serveur
PORT=3001

# Environnement (development, production, test)
NODE_ENV=development

# Clé secrète JWT (générer une clé forte pour la production)
JWT_SECRET=votre_cle_secrete_a_changer_en_production_minimum_32_caracteres

# Durée de validité du token JWT (en heures)
JWT_EXPIRES_IN=8

# Base de données
DATABASE_PATH=./database/tst_manager.db

# URL Frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# Configuration des logs
LOG_LEVEL=debug
